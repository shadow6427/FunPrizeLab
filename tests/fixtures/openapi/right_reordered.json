{
  "info": {
    "version": "1.0.0",
    "title": "Sample API"
  },
  "openapi": "3.0.0",
  "paths": {
    "/pets": {
      "get": {
        "responses": {
          "200": { "description": "A paged array of pets" }
        },
        "tags": ["pets"],
        "operationId": "listPets",
        "summary": "List all pets"
      }
    }
  },
  "components": {
    "schemas": {
      "Pet": {
        "properties": {
          "name": { "type": "string" },
          "tag": { "type": "string" },
          "id": { "format": "int64", "type": "integer" }
        },
        "required": ["id", "name"],
        "type": "object"
      }
    }
  }
}
